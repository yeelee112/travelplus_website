# Disable directory browsing
Options -Indexes

# Use branded pages for errors generated directly by Apache.
ErrorDocument 403 /error-403.php
ErrorDocument 404 /error-404.php

# Block accidental exposure of source maps, backups, local configs and VCS files.
<FilesMatch "(^\.|\.map$|\.log$|\.sql$|\.bak$|\.old$|\.orig$|\.save$|\.swp$|\.tmp$|\.env$|\.ini$|\.ya?ml$|\.lock$|composer\.(json|lock)$|package(-lock)?\.json$)">
	Require all denied
</FilesMatch>

<IfModule mod_headers.c>
	Header onsuccess unset X-Content-Type-Options
	Header onsuccess unset Referrer-Policy
	Header onsuccess unset X-Powered-By
	Header always unset X-Powered-By
	Header always set X-Content-Type-Options "nosniff"
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
	Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"
	Header always set Strict-Transport-Security "max-age=31536000"

	<FilesMatch "\.(?:css|js|mjs)$">
		Header set Cache-Control "public, max-age=31536000, immutable" env=immutable_asset
		Header set Cache-Control "public, max-age=604800, stale-while-revalidate=86400" env=!immutable_asset
	</FilesMatch>
	<FilesMatch "\.(?:avif|png|jpe?g|gif|webp|svg|ico)$">
		Header set Cache-Control "public, max-age=31536000, immutable" env=immutable_asset
		Header set Cache-Control "public, max-age=2592000, stale-while-revalidate=604800" env=!immutable_asset
	</FilesMatch>
	<FilesMatch "\.(?:woff2?|ttf|otf)$">
		Header set Cache-Control "public, max-age=31536000, immutable"
	</FilesMatch>
	<FilesMatch "\.(?:pdf|docx?|xlsx?|json|xml|txt)$">
		Header set Cache-Control "public, max-age=31536000, immutable" env=immutable_asset
		Header set Cache-Control "public, max-age=86400, must-revalidate" env=!immutable_asset
	</FilesMatch>
</IfModule>

<IfModule mod_expires.c>
	ExpiresActive On
	ExpiresByType text/css "access plus 7 days"
	ExpiresByType application/javascript "access plus 7 days"
	ExpiresByType text/javascript "access plus 7 days"
	ExpiresByType image/avif "access plus 1 month"
	ExpiresByType image/svg+xml "access plus 1 month"
	ExpiresByType image/webp "access plus 1 month"
	ExpiresByType image/jpeg "access plus 1 month"
	ExpiresByType image/png "access plus 1 month"
	ExpiresByType image/gif "access plus 1 month"
	ExpiresByType image/x-icon "access plus 1 month"
	ExpiresByType font/woff2 "access plus 1 year"
	ExpiresByType font/woff "access plus 1 year"
	ExpiresByType application/pdf "access plus 1 day"
	ExpiresByType application/json "access plus 1 day"
</IfModule>

<IfModule mod_deflate.c>
	AddOutputFilterByType DEFLATE text/html text/plain text/css text/xml
	AddOutputFilterByType DEFLATE application/javascript application/x-javascript text/javascript
	AddOutputFilterByType DEFLATE application/json application/xml image/svg+xml
</IfModule>

# ----------------------------------------------------------------------
# Rewrite engine
# ----------------------------------------------------------------------

# Turning on the rewrite engine is necessary for the following rules and features.
# FollowSymLinks must be enabled for this to work.
<IfModule mod_rewrite.c>
	Options +FollowSymlinks
	RewriteEngine On

	# Versioned bundles and uniquely named uploads can be cached permanently.
	RewriteCond %{QUERY_STRING} (^|&)v=[0-9]+(&|$) [NC]
	RewriteRule ^ - [E=immutable_asset:1]
	RewriteRule ^uploads/ - [E=immutable_asset:1]

	# If you installed CodeIgniter in a subfolder, you will need to
	# change the following line to match the subfolder you need.
	# http://httpd.apache.org/docs/current/mod/mod_rewrite.html#rewritebase
	# RewriteBase /

	# LiteSpeed renders its own 403 page for a real directory without an index.
	# Route that request through the lightweight branded error controller instead.
	RewriteCond %{REQUEST_FILENAME} -d
	RewriteCond %{REQUEST_FILENAME}/index.php !-f
	RewriteCond %{REQUEST_FILENAME}/index.html !-f
	RewriteCond %{REQUEST_FILENAME}/index.htm !-f
	RewriteRule ^.+/?$ error-403.php [L]

	# Drop malformed paths and common scanner probes before they boot CodeIgniter.
	# RewriteRule only inspects the URL path, so legitimate query-string separators
	# are not affected by the ampersand rule.
	RewriteRule ^.*&.*$ - [F,L,NC]
	RewriteRule ^(?:\.env|\.git|\.svn|\.hg)(?:/|$) - [F,L,NC]
	RewriteRule ^(?:wp-admin|wp-content|wp-includes)(?:/|$) - [F,L,NC]
	RewriteRule ^(?:wp-login\.php|xmlrpc\.php|wp-cron\.php)(?:/|$) - [F,L,NC]
	RewriteRule ^(?:phpmyadmin|pma|adminer)(?:/|$) - [F,L,NC]
	RewriteRule ^(?:vendor/phpunit|cgi-bin|server-status|actuator)(?:/|$) - [F,L,NC]

	# Block percent-encoded non-ASCII spam URLs before CodeIgniter handles them.
	RewriteCond %{THE_REQUEST} \s/+[^\s?]*%[89A-Fa-f][0-9A-Fa-f] [NC]
	RewriteRule ^ - [F,L]

	# Block encoded/raw angle brackets and fake search paths used by spam bots.
	RewriteCond %{THE_REQUEST} (?:%3C|%3E|[<>]) [NC]
	RewriteRule ^ - [F,L]

	RewriteRule ^tim/ - [F,L,NC]

	# Legacy paths from the old site should not hit CodeIgniter catch-all routes.
	RewriteRule ^timthumb/ - [G,L,NC]
	RewriteRule ^nhom-san-pham/ - [G,L,NC]

	# Redirect Trailing Slashes...
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteCond %{REQUEST_URI} (.+)/$
	RewriteRule ^ %1 [L,R=301]

	# Rewrite "www.example.com -> example.com"
	RewriteCond %{HTTPS} !=on
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^ http://%1%{REQUEST_URI} [R=301,L]

	# Missing static files use the lightweight branded 404 page instead of
	# booting CodeIgniter or falling back to LiteSpeed's default error page.
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^(?:assets|uploads)/.+\.(?:css|m?js|avif|webp|png|jpe?g|gif|svg|ico|pdf|docx?|xlsx?|woff2?|ttf|otf|map|json|xml|txt)$ error-404.php [L,NC]

	# Checks to see if the user is attempting to access a valid file,
	# such as an image or css document, if this isn't true it sends the
	# request to the front controller, index.php
	RewriteCond %{REQUEST_FILENAME} !-f
	RewriteCond %{REQUEST_FILENAME} !-d
	RewriteRule ^([\s\S]*)$ index.php/$1 [L,NC,QSA]

	# Ensure Authorization header is passed along
	RewriteCond %{HTTP:Authorization} .
	RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>

<IfModule !mod_rewrite.c>
	# If we don't have mod_rewrite installed, all 404's
	# can be sent to index.php, and everything works as normal.
	ErrorDocument 404 index.php
</IfModule>


# Disable server signature start
ServerSignature Off
# Disable server signature end
