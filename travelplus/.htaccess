Options -Indexes

# Use the branded CodeIgniter error pages for errors raised at the hosting root.
ErrorDocument 403 /error-403.php
ErrorDocument 404 /error-404.php

<FilesMatch "(^\.|\.env$|\.ini$|\.log$|\.sql$|\.bak$|\.old$|\.orig$|\.save$|\.swp$|\.tmp$|\.ya?ml$|\.lock$|composer\.(json|lock)$|package(-lock)?\.json$)">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{THE_REQUEST} \s/+public/?([^\s?]*) [NC]
    RewriteRule ^public/?(.*)$ /$1 [R=301,L,NE]

    RewriteCond %{THE_REQUEST} \s/+[^\s?]*%[89A-Fa-f][0-9A-Fa-f] [NC]
    RewriteRule ^ - [F,L]

    RewriteCond %{THE_REQUEST} (?:%3C|%3E|[<>]) [NC]
    RewriteRule ^ - [F,L]

    RewriteRule ^tim/ - [F,L,NC]

    RewriteRule ^timthumb/ - [G,L,NC]
    RewriteRule ^nhom-san-pham/ - [G,L,NC]

    RewriteRule ^(?:app|build|database|scripts|tests|vendor|writable)(?:/|$) - [F,L]
    RewriteRule ^(?:spark|preload\.php|phpunit\.xml\.dist|README\.md|LICENSE|DATABASE_.*\.md|tour_detail_schema_update\.sql|travelplus\.zip)$ - [F,L]

    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 /public/index.php
</IfModule>
