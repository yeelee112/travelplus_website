.home-promo-list__scroller .home-promo-card:nth-child(n + 2) .home-promo-card__arrow{
        width: 34px;
        height: 34px;
        flex-basis: 34px;
        font-size: 15px;
    }
}
@media (min-width: 768px) and (max-width: 1199px){.home-promo-list__scroller{
        height: auto;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        grid-template-rows: none;
    }
.home-promo-card__link-full{
        grid-template-rows: 170px minmax(0, 1fr);
    }
}
@media (max-width: 767px){.home-promo-list__scroller{
        display: grid;
        grid-template-columns: none;
        grid-template-rows: none;
        grid-auto-columns: minmax(286px, 84vw);
        grid-auto-flow: column;
        gap: 12px;
        overflow-x: auto;
        overscroll-behavior-inline: contain;
        scroll-snap-type: inline mandatory;
        scrollbar-width: none;
    }
.home-promo-list__scroller::-webkit-scrollbar{
        display: none;
    }
.home-promo-list__scroller .home-promo-card{
        scroll-snap-align: start;
    }
.home-promo-card__link-full{
        grid-template-rows: 176px minmax(0, 1fr);
    }
.home-promo-card__body{
        min-height: 190px;
    }
}
