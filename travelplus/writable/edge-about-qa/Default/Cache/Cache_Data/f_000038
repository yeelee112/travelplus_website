.breadcrumb{display: flex;
    flex-wrap: nowrap;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
    font-weight: 600;
    max-width: 100%;
    overflow: hidden;}
.breadcrumb-wrapper{max-width: 100%;
    overflow: hidden;}
.breadcrumb-item{display: inline-flex;
    align-items: center;
    min-width: 0;
    line-height: 1.35;}
.breadcrumb-separator{display: inline-flex;
    flex: 0 0 auto;
    align-items: center;
    justify-content: center;
    margin: 0 10px;
    color: rgba(var(--title-color-opc), 0.5);
    font-size: 13px;
    line-height: 1;}
.breadcrumb-separator i{display: inline-flex;}
.breadcrumb a{text-decoration: none;
    color: #333;}
.breadcrumb a:hover{text-decoration: underline;}
.breadcrumb-item.active{color: var(--black-color);
    flex: 1 1 auto;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;}
.breadcrumb-item:not(.active){flex: 0 0 auto;}
.breadcrumb-item a{overflow: hidden;
