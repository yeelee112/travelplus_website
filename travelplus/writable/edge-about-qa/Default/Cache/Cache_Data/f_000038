.progress-wrap{position: fixed;
    right: 30px;
    bottom: 90px;
    height: 45px;
    width: 45px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    box-shadow: inset 0 0 0 2px var(--borders-color);
    background-color: transparent;
    z-index: 1030;
    opacity: 0;
    visibility: hidden;
    transform: translateY(15px);
    transition: all .2s linear}
.progress-wrap.active-progress{opacity: 1;
    visibility: visible;
    transform: translateY(0)}
.progress-wrap svg{fill: none;
    transition: .5s}
