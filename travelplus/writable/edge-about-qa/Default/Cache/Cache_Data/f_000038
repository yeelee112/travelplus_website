    white-space: nowrap;}
@media (max-width: 575px){.breadcrumb{font-size: 14px;}
.breadcrumb-item:not(:first-child):not(.active){max-width: 44vw;}
.breadcrumb-separator{margin: 0 7px;
        font-size: 12px;}
}
.tour-departure-picker{position: relative;
    margin-bottom: 12px;}
.tour-departure-trigger{display: grid;
    width: 100%;
    min-height: 52px;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 6px 12px;
    padding: 8px 12px;
    border: 1px solid rgba(14, 169, 208, 0.26);
    border-radius: 8px;
    background: #f8fcff;
    color: var(--title-color);
    text-align: left;
    transition: border-color .18s ease, background .18s ease, box-shadow .18s ease;}
.tour-departure-trigger:hover, .tour-departure-picker.is-open .tour-departure-trigger{border-color: var(--primary-color1);
    background: #fff;
    box-shadow: 0 8px 22px rgba(14, 169, 208, 0.12);}
.tour-departure-trigger-copy{grid-column: 1 / -1;
    color: rgba(var(--title-color-opc), 0.64);
    font-size: 12px;
    font-weight: 700;
    line-height: 1;}
.tour-departure-trigger-price-label{grid-column: 1 / -1;
    color: rgba(var(--title-color-opc), 0.58);
    font-size: 11px;
    font-weight: 850;
    line-height: 1;
    text-transform: uppercase;}
.tour-departure-trigger strong{color: var(--title-color);
    font-size: 19px;
    line-height: 1.15;}
.tour-departure-trigger > span[data-departure-current-price]{color: var(--primary-color1);
    font-size: 20px;
    font-weight: 800;
    white-space: nowrap;}
.tour-departure-trigger i{color: rgba(var(--title-color-opc), 0.54);
    transition: transform .18s ease;}
.tour-departure-picker.is-open .tour-departure-trigger i{transform: rotate(180deg);}
.tour-departure-menu{position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 8px);
    z-index: 30;
    display: none;
    max-height: 198px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 6px;
    padding: 8px;
    overflow-y: auto;
    border: 1px solid rgba(14, 169, 208, 0.22);
    border-radius: 10px;
    background: #fff;
    box-shadow: 0 18px 40px rgba(17, 15, 15, 0.14);}
.tour-departure-picker.is-open .tour-departure-menu{display: grid;}
.tour-departure-option{display: grid;
    min-height: 64px;
    grid-template-columns: minmax(68px, auto) minmax(0, 1fr);
    align-items: center;
    gap: 2px 10px;
    padding: 7px 9px;
    border: 1px solid #dbe7ef;
    border-radius: 8px;
    background: #fff;
    color: var(--title-color);
    text-align: left;
    transition: border-color .18s ease, background .18s ease, box-shadow .18s ease;}
.tour-departure-option strong{grid-column: 1;
    grid-row: 1 / 3;
    align-self: center;
    font-size: 18px;
    line-height: 1.1;}
.tour-departure-option strong span{display: block;
    margin-bottom: 2px;
    color: rgba(var(--title-color-opc), 0.54);
    font-size: 10px;
    font-weight: 850;
    line-height: 1;
    text-transform: uppercase;}
.tour-departure-option small{grid-column: 2;
    grid-row: 1;
    align-self: end;
    color: rgba(var(--title-color-opc), 0.52);
    font-size: 10px;
    font-weight: 850;
    line-height: 1;
    text-transform: uppercase;}
.tour-departure-option em{grid-column: 2;
    grid-row: 2;
    align-self: start;
    color: var(--primary-color1);
    font-size: 13px;
    font-style: normal;
    font-weight: 800;
    line-height: 1.1;
    white-space: nowrap;}
.tour-departure-option.is-active, .tour-departure-option:hover{border-color: var(--primary-color1);
    background: rgba(14, 169, 208, 0.08);
    box-shadow: 0 8px 18px rgba(14, 169, 208, 0.10);}
.tour-departure-meta{margin-top: 8px;
    color: rgba(var(--title-color-opc), 0.68);
    font-size: 13px;
    line-height: 1.45;}
@media (max-width: 991px){.tour-departure-menu{grid-template-columns: repeat(3, minmax(0, 1fr));}
}
@media (max-width: 767px){.tour-departure-menu{grid-template-columns: repeat(2, minmax(0, 1fr));}
}
@media (max-width: 575px){.tour-departure-trigger{grid-template-columns: 1fr auto;}
.tour-departure-trigger > span[data-departure-current-price]{grid-column: 1 / 2;}
.tour-departure-menu{grid-template-columns: repeat(2, minmax(0, 1fr));}
}
@media (max-width: 420px){.tour-departure-menu{grid-template-columns: 1fr;}
}
.tp-skeleton{display: block;
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    background: #e8eef5;}
.tp-skeleton::after{content: "";
    position: absolute;
    inset: 0;
    transform: translateX(-100%);
    background: linear-gradient(90deg, transparent, rgba(255, 255, 255, .65), transparent);
    animation: tpSkeletonShimmer 1.25s infinite;}
.tp-skeleton-line{height: 12px;
    margin: 7px 0;}
.tp-skeleton-line--wide{width: min(220px, 78%);}
.tp-skeleton-line--short{width: min(140px, 48%);}
