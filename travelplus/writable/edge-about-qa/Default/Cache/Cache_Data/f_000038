        border-top: 4px solid #ffc94a;
    }
.home-promo-list__scroller .home-promo-card:nth-child(3){
        border-top: 4px solid var(--primary-color1);
    }
.home-promo-list__scroller .home-promo-card:nth-child(n + 2) .home-promo-card__body{
        gap: 7px;
        padding: 12px 14px 14px;
    }
.home-promo-list__scroller .home-promo-card:nth-child(n + 2) h3{
        font-size: 15px;
