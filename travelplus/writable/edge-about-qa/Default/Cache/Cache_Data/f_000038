    gap: 14px;
    align-items: center;
    padding: 12px 14px;
    border-color: #e59b00;
    background: #ffb627;
    box-shadow: 0 13px 28px rgba(123, 72, 0, .24);
}
.home-promo-countdown__label{
    display: inline-flex;
    gap: 7px;
    align-items: center;
    color: #3c2a00;
    font-size: 11px;
    text-transform: uppercase;
}
.home-promo-countdown__grid{
    gap: 6px;
}
.home-promo-countdown__grid span{
    grid-template-columns: auto auto;
    gap: 4px;
    align-items: baseline;
    justify-content: center;
    padding: 6px;
    border: 1px solid rgba(132, 78, 0, .18);
    border-radius: 6px;
    background: rgba(255, 255, 255, .72);
    color: #8f2f20;
}
.home-promo-countdown__grid strong{
    font-size: 17px;
}
.home-promo-countdown__grid small{
    color: #684900;
    font-size: 9px;
}
@media (max-width: 1199px){.home-promo-head{
        grid-template-columns: 1fr;
    }
.home-promo-head__aside{
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
    }
.home-promo-layout{
        grid-template-columns: 1fr;
    }
.home-promo-feature{
        grid-template-columns: minmax(300px, .88fr) minmax(0, 1.12fr);
        grid-template-rows: none;
    }
.home-promo-feature__media img{
        height: 100%;
        aspect-ratio: auto;
    }
.home-promo-list__scroller{
        grid-template-columns: repeat(3, minmax(0, 1fr));
        grid-template-rows: none;
    }
.home-promo-card{
        grid-template-columns: 1fr;
        grid-template-rows: 170px minmax(0, 1fr);
    }
}
@media (max-width: 767px){.home-promo-section{
        padding: 56px 0;
    }
.home-promo-head{
        gap: 20px;
        margin-bottom: 24px;
    }
.home-promo-head__copy h2{
        font-size: 30px;
    }
.home-promo-head__aside{
        display: grid;
        width: 100%;
        justify-items: start;
    }
.home-promo-feature{
        grid-template-columns: 1fr;
        grid-template-rows: auto auto;
    }
.home-promo-feature__media img{
        height: auto;
        aspect-ratio: 1.55 / 1;
    }
.home-promo-feature__facts{
        grid-template-columns: minmax(0, 1fr) auto;
    }
.home-promo-feature__facts .home-promo-link{
        grid-column: 1 / -1;
        width: 100%;
        justify-self: stretch;
    }
.home-promo-list__scroller{
        grid-template-columns: 1fr;
    }
.home-promo-card{
        grid-template-columns: 148px minmax(0, 1fr);
        grid-template-rows: none;
    }
}
@media (max-width: 575px){.home-promo-head__signals{
        width: 100%;
        gap: 14px;
    }
.home-promo-head__signals > span{
        min-width: 0;
        flex: 1;
    }
.home-promo-head__signals > span + span{
        padding-left: 14px;
    }
.home-promo-feature__body{
        padding: 19px;
    }
.home-promo-feature h3{
        font-size: 24px;
    }
.home-promo-feature__facts{
        gap: 14px 10px;
    }
.home-promo-feature__facts .home-promo-price{
        padding: 10px 12px;
    }
.home-promo-price strong{
        font-size: 24px;
    }
.home-promo-departure{
        padding-left: 12px;
    }
.home-promo-countdown{
        grid-template-columns: 1fr;
    }
.home-promo-list__scroller{
        grid-template-columns: none;
        grid-template-rows: none;
    }
.home-promo-list__scroller > .home-promo-card{
        grid-template-columns: 1fr;
        grid-template-rows: auto 1fr;
    }
.home-promo-list__scroller .home-promo-card__media{
        aspect-ratio: 1.6 / 1;
    }
.home-promo-list__scroller .home-promo-card__body{
        padding: 17px;
    }
.home-promo-list__scroller .home-promo-card__footer{
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: end;
    }
.home-promo-list__scroller .home-promo-card__link{
        width: auto;
        justify-content: flex-end;
    }
}
@media (max-width: 360px){.home-promo-feature__facts{
        grid-template-columns: 1fr;
    }
.home-promo-departure{
        padding-top: 12px;
        padding-left: 0;
        border-top: 1px solid #e3eaed;
        border-left: 0;
    }
.home-promo-feature__facts .home-promo-link{
        grid-column: 1;
    }
}
.home-promo-card{
    position: relative;
    display: block;
    min-height: 0;
    overflow: hidden;
    border: 1px solid #dce6ea;
    border-radius: 8px;
    background: #fff;
    box-shadow: 0 12px 30px rgba(19, 49, 63, .09);
    transition: transform .2s ease, border-color .2s ease, box-shadow .2s ease;
}
.home-promo-card:hover{
    border-color: #b9d5df;
    box-shadow: 0 18px 38px rgba(19, 49, 63, .14);
    transform: translateY(-3px);
}
.home-promo-card__link-full{
    display: grid;
    width: 100%;
    height: 100%;
    color: inherit;
}
.home-promo-card__link-full:focus-visible{
    outline: 3px solid rgba(var(--primary-color1-opc), .4);
    outline-offset: -3px;
}
.home-promo-card__media{
    min-width: 0;
}
.home-promo-card__body{
    display: flex;
    min-width: 0;
    flex-direction: column;
    gap: 9px;
    padding: 15px 16px;
    border: 0;
    background: #fff;
}
.home-promo-card__content{
    display: grid;
    gap: 8px;
}
.home-promo-card h3{
    display: block;
    overflow: hidden;
    margin: 0;
    color: var(--title-color);
    font-size: 17px;
    font-weight: 900;
    line-height: 1.28;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.home-promo-card__meta{
    display: flex;
    flex-wrap: wrap;
    gap: 6px 12px;
}
.home-promo-card__meta span{
    display: inline-flex;
    min-height: 0;
    align-items: center;
    gap: 5px;
    padding: 0;
    background: transparent;
    color: rgba(var(--title-color-opc), .6);
    font-size: 11px;
    font-weight: 750;
    line-height: 1.3;
}
.home-promo-card__meta i{
    color: var(--primary-color1);
}
.home-promo-card__departure{
    display: inline-flex;
    width: fit-content;
    min-height: 27px;
    align-items: center;
    gap: 6px;
    padding: 5px 9px;
    border-radius: 6px;
    background: #edf8fc;
    color: #236277;
    font-size: 11px;
    font-weight: 850;
    line-height: 1;
}
.home-promo-card__departure i{
    color: var(--primary-color1);
}
.home-promo-card__footer{
    display: flex;
    width: 100%;
    align-items: end;
    justify-content: space-between;
    gap: 12px;
    margin-top: auto;
    padding-top: 10px;
    border-top: 1px solid #e7eef1;
}
.home-promo-card__footer .home-promo-card__price{
    display: grid;
    gap: 3px;
    padding: 0;
    border: 0;
    background: transparent;
}
.home-promo-card__price span{
    color: #a74246;
    font-size: 10px;
}
.home-promo-card__price strong{
    color: #df3f45;
    font-size: 20px;
    line-height: 1.05;
}
.home-promo-card__arrow{
    display: inline-flex;
    width: 38px;
    height: 38px;
    flex: 0 0 38px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--primary-color1);
    color: #fff;
    font-size: 17px;
    box-shadow: 0 10px 22px rgba(var(--primary-color1-opc), .22);
    transition: background .2s ease, transform .2s ease;
}
.home-promo-card:hover .home-promo-card__arrow{
    background: #0087bd;
    transform: translate(2px, -2px);
}
@media (min-width: 1200px){.home-promo-list__scroller{
        height: 538px;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        grid-template-rows: 214px 314px;
        gap: 10px;
    }
.home-promo-list__scroller .home-promo-card:first-child{
        grid-column: 1 / -1;
    }
.home-promo-list__scroller .home-promo-card:first-child .home-promo-card__link-full{
        grid-template-columns: minmax(220px, .82fr) minmax(0, 1.18fr);
    }
.home-promo-list__scroller .home-promo-card:first-child .home-promo-card__body{
        padding: 18px 20px;
        border-left: 4px solid #ed4d4d;
        background: #fbfdfe;
    }
